{
  "name": "focus-timer-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json && cp src/render.yaml dist/render.yaml && cp package.json dist/package.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:migrate": "psql \"$POSTGRESS_DATABASE_CONNECTION_URL\" -f migrations/0003_postgres_schema.sql && psql \"$POSTGRESS_DATABASE_CONNECTION_URL\" -f migrations/0004_endpoint_audit.sql"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "pg": "^8.13.3",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.1",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
